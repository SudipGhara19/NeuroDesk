MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/neuro-desk?retryWrites=true&w=majority
PORT=5868
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars

# Pinecone Vector DB
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=neuro-desk

# Groq LLM API
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Redis Cache (optional — app works without this)
REDIS_URL=redis://default:password@host:port

# Environment
NODE_ENV=development

# Email (optional — for future notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
